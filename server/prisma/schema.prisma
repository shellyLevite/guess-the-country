// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id    Int    @id @default(autoincrement())
  name  String @unique
  clue1 String
  clue2 String
  clue3 String
}
