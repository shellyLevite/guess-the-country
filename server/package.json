{
  "name": "guess-the-country-server",
  "version": "1.0.0",
  "description": "Fastify backend for Guess The Country",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "ts-node-dev --transpile-only src/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/pg": "^8.18.0",
    "prisma": "^7.4.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3"
  }
}
